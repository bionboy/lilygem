{
  "name": "lilygem",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:secrets": "infisical run --env=dev --path=/ -- bun run dev",
    "build": "next build",
    "build:secrets": "infisical run --env=dev --path=/ -- bun run build",
    "start": "next start",
    "start:secrets": "infisical run --env=dev --path=/ -- bun run start",
    "lint": "next lint",
    "shadcn": "bunx shadcn@latest add",
    "cron": "source .env.local && curl -X GET \"http://localhost:3000/api/cron/exchange-rates\" -H \"Authorization: Bearer $CRON_SECRET\"",
    "cron:secrets": "infisical run --env=dev --path=/ --command 'curl -X GET \"http://localhost:3000/api/cron/exchange-rates\" -H \"Authorization: Bearer $CRON_SECRET\"'",
    "env:pull:infisical": "infisical export --env=dev --path=/ --format=dotenv --output-file=.env.local",
    "env:pull:vercel": "vercel env pull .env.local"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-query-devtools": "^5.95.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "luxon": "^3.7.2",
    "next": "15.4.10",
    "next-auth": "5.0.0-beta.29",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.4.10",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
